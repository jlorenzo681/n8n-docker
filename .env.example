# ══════════════════════════════════════════════════════════════════════
#  N8N Docker Stack – Environment Variables
#  Copy this file to .env and fill in the values:  cp .env.example .env
# ══════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=n8n

# ── n8n ───────────────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Madrid

# Generate a random key:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Ollama ─────────────────────────────────────────────────────────────
# Base URL used by n8n to reach Ollama
# Podman:  http://host.containers.internal:11434
# Docker:  http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434
# Used by the cpu profile
OLLAMA_MODEL_CPU=hf.co/LiquidAI/LFM2.5-1.2B-Instruct-GGUF:Q4_K_M
# Used by the gpu profile
OLLAMA_MODEL_GPU=mistral

# ── Juniper Mist API ─────────────────────────────────────────────────
# Your Mist API token (Organization or User token)
MIST_API_TOKEN=CHANGE_ME_your_mist_api_token

# Regional endpoint (derived from your Mist portal URL)
# Examples: https://api.mist.com/api/v1  |  https://api.eu.mist.com/api/v1
MIST_API_BASE_URL=https://api.eu.mist.com/api/v1
